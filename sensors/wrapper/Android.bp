cc_library_shared {
    name: "sensors.wrapper",
    defaults: ["hidl_defaults"],
    srcs: [
        "AlsCorrection.cpp",
        "SensorsSubHal.cpp",
    ],
    shared_libs: [
        "android.hardware.sensors@2.0",
        "android.hardware.sensors@2.0-ScopedWakelock",
        "android.hardware.sensors@2.1",
        "libbase",
        "libbinder",
        "libbinder_ndk",
        "liblog",
        "libhidlbase",
        "libutils",
        "vendor.lineage.oplus_als-V1-ndk",
    ],
    header_libs: [
        "android.hardware.sensors@2.X-multihal.header",
        "libhardware_headers",
    ],
    cflags: [
        "-DLOG_TAG=\"sensors.wrapper\"",
    ] + select(soong_config_variable("oplus_sensors", "wrapped_lib_name"), {
        any @ flag_val: ["-DWRAPPED_LIB_NAME=\"" + flag_val + "\""],
        default: [],
    }),
    vendor: true,
}
