package vendor.oplus.hardware.displaypanelfeature@1.0;

interface IDisplayPanelFeature {
    getDisplayPanelFeatureValue(int32_t featureId) generates (int32_t status, vec<int32_t> values);
    setDisplayPanelFeatureValue(int32_t featureId, vec<int32_t> values) generates (int32_t status);
    getDisplayPanelInfo(int32_t featureId) generates (int32_t status, vec<string> info);
};
